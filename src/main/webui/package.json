{
  "name": "webui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "biome:lint": "node ./node_modules/@biomejs/biome/bin/biome lint ./src",
    "biome:check": "node ./node_modules/@biomejs/biome/bin/biome check ./src",
    "biome:fix": "node ./node_modules/@biomejs/biome/bin/biome lint --write ./src",
    "biome:format": "node ./node_modules/@biomejs/biome/bin/biome format --write ./src",
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
